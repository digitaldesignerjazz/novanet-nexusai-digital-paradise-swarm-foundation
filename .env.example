# Environment configuration for Digital Paradise Swarm Foundation
# Copy to .env and customize

# Nexus AI / LLM settings
LLM_PROVIDER=local          # local | xai | ollama
XAI_API_KEY=your_key_here   # only if using xAI/Grok as Oracle
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Mesh / NovaNet
MESH_ENDPOINT=novanet-node:12345
NODE_NAME=DigitalParadise-Hannover-01
SWARM_SIZE=4
PARADISE_MODE=demo

# Optional: Blockchain / QCoin
QCOIN_RPC_URL=

# Privacy / Tor-I2P (future)
# I2P_GATEWAY=
